# Copy to .env and adjust as needed.

# --- Postgres ---
POSTGRES_USER=nadlan
POSTGRES_PASSWORD=nadlan
POSTGRES_DB=nadlan
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Ports exposed on the host ---
POSTGRES_HOST_PORT=5434        # change if 5434 is also taken
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Backend behaviour ---
LISTING_SOURCE=sample          # sample (default, uses bundled data) | yad2 (live Yad2 JSON API, no Playwright needed)
SCRAPE_RATE_LIMIT_S=3
AUTO_SEED=true                 # auto-import bundled sample CSV when transactions table is empty
LOG_LEVEL=INFO

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
